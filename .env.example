# Neon PostgreSQL connection URL (Drizzle ORM + better-auth)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# better-auth secret (session encryption)
BETTER_AUTH_SECRET=your-secret-key-here-min-32-chars

# Neon API key (optional, for management tasks)
NEON_API_KEY=

# Encryption for sensitive device data
ENCRYPTION_KEY=your-encryption-key-min-32-chars

# LLM (Claude) API key for invoice parsing
ANTHROPIC_API_KEY=

# Email provider (Resend)
RESEND_API_KEY=

# SMS provider (Clickatell/BulkSMS)
SMS_PROVIDER=clickatell
SMS_API_KEY=

# Object storage (Cloudflare R2 / AWS S3)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Environment
NODE_ENV=development
ENVIRONMENT=dev
