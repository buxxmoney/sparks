# Copy to .env and fill in real values. NEVER commit real secrets — .env is
# git-ignored. Do not paste real credentials into docs or markdown either.

# ── Core ─────────────────────────────────────────────────────────────
NODE_ENV=development
# Neon / Postgres connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# Session signing secret — generate with: openssl rand -base64 48
BETTER_AUTH_SECRET=replace-with-a-long-random-string
BETTER_AUTH_URL=http://localhost:3001
# Public web origin(s) allowed by CORS/auth in prod (comma-separated)
WEB_ORIGINS=
# Base URL of the web app (used to build email links)
WEB_URL=http://localhost:3000

# ── Invoice parsing (Anthropic) ──────────────────────────────────────
ANTHROPIC_API_KEY=
# Optional model override, e.g. claude-sonnet-5
INVOICE_PARSE_MODEL=

# ── Email (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Sparks <noreply@yourdomain.com>
# Where "please review this bill" emails go (comma-separated for multiple)
SPARKS_REVIEW_EMAIL=

# ── Object storage (Cloudflare R2) ───────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Force filesystem storage even if R2 vars are set: STORAGE_BACKEND=fs

# ── SMS (Clickatell One API, optional) ───────────────────────────────
# Set SMS_PROVIDER=clickatell to enable the "your bill review is ready" text.
SMS_PROVIDER=clickatell
# Clickatell One-API integration key (sent raw in the Authorization header).
SMS_API_KEY=
# Optional sender ID / number (else the integration's default sender is used).
SMS_FROM=
# Optional endpoint override (defaults to https://platform.clickatell.com/messages).
SMS_API_URL=

# ── Device ingestion (POST /ingest/raw) ──────────────────────────────
# RSA PUBLIC key (PEM/SPKI) that verifies device JWTs. The matching PRIVATE key is
# generated + kept OFFLINE and used to mint per-device tokens (scripts/mint-device-jwt.ts);
# it must NEVER be set on the server. Paste the full PEM incl. the BEGIN/END lines.
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out device-signing.private.pem
#   openssl rsa -in device-signing.private.pem -pubout -out device-signing.public.pem
DEVICE_INGEST_JWT_PUBLIC_KEY=

# ── Misc ─────────────────────────────────────────────────────────────
ENCRYPTION_KEY=
NEON_API_KEY=
